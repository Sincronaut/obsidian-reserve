{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#FFFFFF",
					"name": "Base (White)",
					"slug": "base"
				},
				{
					"color": "#0B0B0B",
					"name": "Contrast (Black)",
					"slug": "contrast"
				},
				{
					"color": "#C5A059",
					"name": "Gold",
					"slug": "accent-1"
				},
				{
					"color": "#F3F4F6",
					"name": "Light Gray",
					"slug": "accent-2"
				}
			]
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1920px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "Tiny",
					"size": "8px",
					"slug": "20"
				},
				{
					"name": "X-Small",
					"size": "16px",
					"slug": "30"
				},
				{
					"name": "Small",
					"size": "24px",
					"slug": "40"
				},
				{
					"name": "Section Padding Vertical",
					"size": "clamp(10px, 2vw, 30px)",
					"slug": "section-padding-v"
				},
				{
					"name": "Section Padding Horizontal",
					"size": "clamp(24px, 10vw, 150px)",
					"slug": "section-padding-h"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"writingMode": true,
			"defaultFontSizes": false,
			"fluid": true,
			"fontSizes": [
				{
					"fluid": false,
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "1.125rem",
						"min": "1rem"
					},
					"name": "Medium",
					"size": "1.125rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "1.5rem",
						"min": "1.25rem"
					},
					"name": "Large",
					"size": "1.5rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "2.5rem",
						"min": "1.75rem"
					},
					"name": "Extra Large",
					"size": "2.5rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "4rem",
						"min": "2.5rem"
					},
					"name": "Extra Extra Large",
					"size": "4rem",
					"slug": "xx-large"
				}
			],
			"fontFamilies": [
				{
					"name": "Montserrat",
					"slug": "montserrat",
					"fontFamily": "Montserrat, sans-serif"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"top": "var:preset|spacing|section-padding-v",
				"bottom": "var:preset|spacing|section-padding-v",
				"left": "var:preset|spacing|section-padding-h",
				"right": "var:preset|spacing|section-padding-h"
			}
		},
		"typography": {
			"fontFamily": "var:preset|font-family|montserrat",
			"fontSize": "var:preset|font-size|medium",
			"fontWeight": "500",
			"lineHeight": "1.6"
		},
		"blocks": {
			"core/button": {
				"typography": {
					"fontFamily": "var:preset|font-family|montserrat",
					"fontWeight": "600",
					"fontSize": "18px",
					"lineHeight": "1"
				},
				"border": {
					"radius": "5px"
				},
				"spacing": {
					"padding": {
						"top": "22px",
						"bottom": "22px",
						"left": "40px",
						"right": "40px"
					}
				},
				"variations": {
					"solid-gold": {
						"color": {
							"background": "#C5A059",
							"text": "#FFFFFF"
						},
						"border": {
							"width": "0px"
						}
					},
					"outline-gold": {
						"color": {
							"background": "transparent",
							"text": "#C5A059"
						},
						"border": {
							"color": "#C5A059",
							"width": "1px",
							"style": "solid"
						}
					}
				}
			},
			"core/columns": {
				"spacing": {
					"blockGap": "var:preset|spacing|50"
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var:preset|font-family|montserrat",
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "600",
					"letterSpacing": "0.5px",
					"textTransform": "uppercase"
				},
				"elements": {
					"link": {
						"color": {
							"text": "currentColor"
						},
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|accent-1"
							}
						}
					}
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|montserrat",
					"fontWeight": "700",
					"letterSpacing": "-0.5px"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|accent-1"
							}
						}
					}
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|accent-1"
							}
						}
					}
				}
			},
			"core/quote": {
				"border": {
					"style": "solid",
					"width": "0 0 0 3px",
					"color": "var:preset|color|accent-1"
				},
				"spacing": {
					"padding": {
						"left": "var:preset|spacing|40"
					}
				},
				"typography": {
					"fontStyle": "italic",
					"fontWeight": "500"
				}
			},
			"core/separator": {
				"border": {
					"color": "currentColor",
					"style": "solid",
					"width": "0 0 1px 0"
				},
				"color": {
					"text": "var:preset|color|accent-5"
				}
			}
		},
		"elements": {
			"button": {
				"color": {
					"background": "var:preset|color|accent-1",
					"text": "var:preset|color|contrast"
				},
				":hover": {
					"color": {
						"background": "var:preset|color|accent-2",
						"text": "var:preset|color|contrast"
					}
				},
				":focus": {
					"outline": {
						"color": "var:preset|color|accent-1",
						"offset": "2px"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|montserrat",
					"fontWeight": "600",
					"fontSize": "var:preset|font-size|medium"
				}
			},
			"caption": {
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "500"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|xx-large",
					"fontWeight": "700"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|x-large",
					"fontWeight": "700"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|large",
					"fontWeight": "700"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|medium",
					"fontWeight": "700"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "700",
					"letterSpacing": "0.5px",
					"textTransform": "uppercase"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "700",
					"letterSpacing": "1px",
					"textTransform": "uppercase"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|montserrat",
					"fontWeight": "700",
					"lineHeight": "1.15",
					"letterSpacing": "-0.02em"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|accent-1"
				},
				"typography": {
					"textDecoration": "underline"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|accent-2"
					},
					"typography": {
						"textDecoration": "none"
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	]
}