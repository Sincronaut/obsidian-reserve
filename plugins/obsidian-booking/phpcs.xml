<?xml version="1.0"?>
<ruleset name="WordPress Plugin Standards">
    <description>A custom set of rules to check for a WordPress theme</description>

    <!-- What to scan -->
    <file>.</file>

    <!-- Folders to ignore (NEVER scan the vendor folder or node_modules) -->
    <exclude-pattern>/vendor/*</exclude-pattern>
    <exclude-pattern>/node_modules/*</exclude-pattern>

    <!-- How to scan -->
    <!-- Usage instructions: https://github.com/squizlabs/PHP_CodeSniffer/wiki/Usage -->
    <!-- Annotate errors with the rule name -->
    <arg value="sp"/> <!-- Show progress and sniff codes -->
    <arg name="colors"/> <!-- Use colors in output -->
    <arg name="extensions" value="php"/> <!-- Only scan PHP files -->

    <!-- Rules: Check against WordPress Extra, Core, and Docs -->
    <rule ref="WordPress-Extra"/>
    <rule ref="WordPress-Docs"/>

    <!-- Check for PHP 8.0+ compatibility -->
    <config name="testVersion" value="8.0-"/>
    <rule ref="PHPCompatibilityWP"/>
</ruleset>